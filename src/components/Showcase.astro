---
// Shared, framework-agnostic showcase. Every page renders THIS exact structure —
// identical section order, headings, grid and spacing. The only thing that varies
// per page is which framework's Kumo components get dropped into the named slots
// (and the version badge in the surrounding Docs chrome). Define once, reuse four
// times: that is what makes the four pages structurally identical.
interface Props {
  title: string;
  subtitle?: string;
}
const { title, subtitle } = Astro.props;
---

<header class="page-head">
  <h1 class="title">{title}</h1>
  {subtitle && <p class="subtitle">{subtitle}</p>}
</header>

<div class="showcase">
  <section class="group">
    <h2 class="label">Buttons</h2>
    <div class="surface"><div class="row"><slot name="buttons" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Badges</h2>
    <div class="surface"><div class="row"><slot name="badges" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Text</h2>
    <div class="surface"><div class="stack"><slot name="text" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Label</h2>
    <div class="surface"><div class="row"><slot name="label" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Inputs</h2>
    <div class="surface"><div class="stack"><slot name="inputs" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Text area</h2>
    <div class="surface"><div class="stack"><slot name="inputarea" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Checkbox</h2>
    <div class="surface"><div class="stack"><slot name="checkbox" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Switch</h2>
    <div class="surface"><div class="row"><slot name="switch" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Tabs</h2>
    <div class="surface"><slot name="tabs" /></div>
  </section>

  <section class="group">
    <h2 class="label">Meter</h2>
    <div class="surface"><div class="stack"><slot name="meter" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Empty state</h2>
    <div class="surface"><slot name="empty" /></div>
  </section>

  <section class="group">
    <h2 class="label">Links</h2>
    <div class="surface"><div class="row"><slot name="links" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Loaders</h2>
    <div class="surface"><div class="row"><slot name="loaders" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Cloudflare logo</h2>
    <div class="surface"><div class="row logo-row"><slot name="logo" /></div></div>
  </section>

  <section class="group">
    <h2 class="label">Code</h2>
    <div class="surface code-surface"><slot name="code" /></div>
  </section>
</div>

<style>
  .page-head { margin: 0 0 3.5rem; }
  h1.title {
    font-size: 2.4rem;
    line-height: 1.1;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--doc-text);
  }
  .subtitle {
    font-size: 1.05rem;
    color: var(--doc-muted);
    margin: 0.75rem 0 0;
    max-width: 46ch;
  }

  .showcase {
    display: flex;
    flex-direction: column;
    gap: 3.5rem;
  }
  .group { display: flex; flex-direction: column; gap: 1rem; }
  .label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--doc-muted);
    margin: 0;
  }
  .surface {
    border: 1px solid var(--doc-line);
    background: var(--doc-panel);
    border-radius: var(--doc-radius);
    padding: 2rem;
  }
  .row {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1.25rem;
  }
  .logo-row :global(svg) { height: 2.25rem; width: auto; }
  .stack {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    max-width: 34rem;
  }
  .code-surface {
    background: #15151a;
    border-color: #23232b;
    color: #e7e7ea;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.85rem;
    line-height: 1.6;
    overflow-x: auto;
  }
  /* Selected-tab bug: Kumo's highlight <span> ships a `-z-10` utility class, but
     this Kumo build never compiled `.-z-10` (only `.z-0` / `.z-10` exist), so the
     span's z-index stays `auto`. As a *positioned* element it then paints ABOVE the
     in-flow label, and its opaque white `bg-kumo-base` pill hides the selected
     tab's text. Push the highlight back behind the label at the demo level. */
  :global([role="tab"] > span[aria-hidden="true"]) {
    z-index: -10;
  }
</style>
