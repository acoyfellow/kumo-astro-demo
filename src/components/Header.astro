---
// Static header with the real installed @cloudflare/kumo version — mirrors the
// golden Header.astro (which reads a __KUMO_VERSION__ build define). Here the
// version is read from node_modules at build time so it can never drift.
import { installedVersion } from '../lib/kumoVersion';

const kumoVersion = installedVersion('@cloudflare/kumo');
---

<header
  class="sticky top-0 z-10 border-b border-kumo-line bg-kumo-elevated pr-12"
>
  <div
    class="mx-auto flex h-12 items-center border-r border-kumo-line px-4"
  >
    <p class="ml-auto font-mono text-base text-kumo-subtle">
      @cloudflare/kumo
      <span class="ml-1 rounded bg-kumo-control px-1.5 py-0.5 text-xs text-kumo-strong">
        v{kumoVersion}
      </span>
    </p>
  </div>
</header>
