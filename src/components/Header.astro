---
// Homepage header — a slim top bar with a package/version badge. On the golden
// `/` route it shows the canonical @cloudflare/kumo version; on the native
// routes it shows the matching compiled-native package (kumo-svelte/vue/solid),
// read from node_modules at build time so the version can never drift.
import { installedVersion } from '../lib/kumoVersion';

interface Props {
  framework?: 'react' | 'svelte' | 'vue' | 'solid';
}
const { framework = 'react' } = Astro.props;

const pkg = framework === 'react' ? '@cloudflare/kumo' : `@acoyfellow/kumo-${framework}`;
const kumoVersion = installedVersion(pkg);
---

<header
  class="sticky top-0 z-10 border-b border-kumo-line bg-kumo-elevated pr-12"
>
  <div
    class="mx-auto flex h-12 items-center border-r border-kumo-line px-4"
  >
    <p class="ml-auto font-mono text-base text-kumo-subtle">
      {pkg}
      <span class="ml-1 rounded bg-kumo-control px-1.5 py-0.5 text-xs text-kumo-strong">
        v{kumoVersion}
      </span>
    </p>
  </div>
</header>
