---
// `/solid` — the kumo-ui.com homepage, rebuilt 1:1 with the compiled-native
// @acoyfellow/kumo-solid components. Same shell (MainLayout + Header) and same
// grid as the golden `/` React route; every Kumo component in the grid is
// native Solid, hydrated as a single island.
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import { HomeGrid } from '../components/solid/HomeGrid';
---

<MainLayout title="Kumo — native Solid" description="Kumo homepage, rendered with native Solid components" framework="solid">
  <div class="flex min-h-screen flex-col">
    <Header framework="solid" />
    <main class="flex grow flex-col pr-12">
      <div class="mx-auto w-full grow border-r border-kumo-line">
        <HomeGrid client:only="solid" />
      </div>
    </main>
  </div>
</MainLayout>
