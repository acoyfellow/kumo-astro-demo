---
// GOLDEN route (`/`): a faithful 1:1 reproduction of the kumo-ui.com homepage
// (cloudflare/fe/kumo → kumo-docs-astro). HomeGrid is the canonical
// @cloudflare/kumo React island rendering all 39 catalog components in a grid.
// This is the baseline the /svelte, /vue and /solid routes diff against.
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import { HomeGrid } from '../components/react/HomeGrid';
---

<MainLayout title="Kumo" description="Kumo – a modern component library">
  <div class="flex min-h-screen flex-col">
    <Header />
    <main class="flex grow flex-col pr-12">
      <div class="mx-auto w-full grow border-r border-kumo-line">
        <HomeGrid client:only="react" />
      </div>
    </main>
  </div>
</MainLayout>
