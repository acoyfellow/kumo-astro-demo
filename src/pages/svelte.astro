---
// Svelte page — Kumo's compiled-native Svelte package (@acoyfellow/kumo-svelte).
// Fills the exact same <Showcase> slots as every other page; only the import
// source and the version badge differ.
import { Button, Badge, Field, Input, Link, Loader, Code } from '@acoyfellow/kumo-svelte';
import Docs from '../layouts/Docs.astro';
import Showcase from '../components/Showcase.astro';
import { installedVersion } from '../lib/kumoVersion';

const kumoVersion = installedVersion('@acoyfellow/kumo-svelte');
---

<Docs title="Kumo components in Astro" active="svelte" kumoPkg="@acoyfellow/kumo-svelte" kumoVersion={kumoVersion}>
  <Showcase
    title="Kumo components in Astro"
    subtitle="Real Kumo components, rendered by Astro — React here, native Svelte, Vue and Solid alongside."
  >
    <Fragment slot="buttons">
      <Button client:load variant="primary">Get started</Button>
      <Button client:load variant="secondary">Docs</Button>
      <Button client:load variant="destructive">Delete</Button>
      <Button client:load variant="outline">Outline</Button>
      <Button client:load variant="ghost">Ghost</Button>
    </Fragment>

    <Fragment slot="badges">
      <Badge client:load variant="success">Stable</Badge>
      <Badge client:load variant="warning">Beta</Badge>
      <Badge client:load variant="error">Deprecated</Badge>
      <Badge client:load variant="info">New</Badge>
      <Badge client:load variant="purple">Experimental</Badge>
    </Fragment>

    <Fragment slot="inputs">
      <Field client:load id="email" label="Work email" />
      <Input client:load placeholder="Search the docs…" />
    </Fragment>

    <Fragment slot="links">
      <Link client:load href="#">Read the docs</Link>
      <Link client:load href="#">View source</Link>
      <Link client:load href="#">Changelog</Link>
    </Fragment>

    <Loader client:load slot="loaders" />

    <Code client:load slot="code" code="npm i @acoyfellow/kumo-svelte" lang="bash" />
  </Showcase>
</Docs>
