---
// `/svelte` — the kumo-ui.com homepage, rebuilt 1:1 with the compiled-native
// @acoyfellow/kumo-svelte components. Same shell (MainLayout + Header) and same
// grid as the golden `/` React route; the only difference is that every Kumo
// component in the grid is native Svelte, hydrated as a single island.
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import HomeGrid from '../components/svelte/HomeGrid.svelte';
---

<MainLayout title="Kumo — native Svelte" description="Kumo homepage, rendered with native Svelte components" framework="svelte">
  <div class="flex min-h-screen flex-col">
    <Header framework="svelte" />
    <main class="flex grow flex-col pr-12">
      <div class="mx-auto w-full grow border-r border-kumo-line">
        <HomeGrid client:only="svelte" />
      </div>
    </main>
  </div>
</MainLayout>
