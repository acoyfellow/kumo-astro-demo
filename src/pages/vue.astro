---
// `/vue` — the kumo-ui.com homepage, rebuilt 1:1 with the compiled-native
// @acoyfellow/kumo-vue components. Same shell (MainLayout + Header) and same
// grid as the golden `/` React route; every Kumo component in the grid is
// native Vue, hydrated as a single island.
import MainLayout from '../layouts/MainLayout.astro';
import Header from '../components/Header.astro';
import HomeGrid from '../components/vue/HomeGrid.vue';
---

<MainLayout title="Kumo — native Vue" description="Kumo homepage, rendered with native Vue components" framework="vue">
  <div class="flex min-h-screen flex-col">
    <Header framework="vue" />
    <main class="flex grow flex-col pr-12">
      <div class="mx-auto w-full grow border-r border-kumo-line">
        <HomeGrid client:only="vue" />
      </div>
    </main>
  </div>
</MainLayout>
